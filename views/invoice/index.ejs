<%- include('../partials/header') %>

<div class="container mt-4">
<h3>Data Invoice</h3>

<a href="/invoice/create" class="btn btn-success mb-3">Tambah Invoice</a>

<table class="table table-bordered">
<thead>
<tr>
<th>No</th>
<th>Nama Pelanggan</th>
<th>Total</th>
<th>Metode</th>
<th>Status</th>
<th>Tanggal</th>
<th>Aksi</th>
</tr>
</thead>

<tbody>
<% invoice.forEach((i, index) => { %>
<tr>
<td><%= index + 1 %></td>
<td><%= i.nama %></td>
<td>Rp <%= i.total %></td>
<td><%= i.metode_pembayaran %></td>
<td><%= i.status_pembayaran %></td>
<td><%= i.tanggal %></td>
<td>
<a href="/invoice/delete/<%= i.id %>" class="btn btn-danger btn-sm">Hapus</a>
</td>
</tr>
<% }) %>
</tbody>

</table>
</div>

<%- include('../partials/footer') %>