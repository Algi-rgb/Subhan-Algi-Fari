<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title><%= title %></title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom Style -->
    <style>
        body {
            background-color: #f5f6fa;
        }

        .sidebar {
            width: 220px;
            height: 100vh;
            position: fixed;
            background-color: #2f3640;
            color: white;
            padding-top: 20px;
        }

        .sidebar h4 {
            text-align: center;
            margin-bottom: 30px;
        }

        .sidebar a {
            display: block;
            color: #dcdde1;
            padding: 12px 20px;
            text-decoration: none;
        }

        .sidebar a:hover {
            background-color: #353b48;
            color: white;
        }

        .sidebar .active {
            background-color: #40739e;
            color: white;
        }

        .content {
            margin-left: 220px;
            padding: 20px;
        }

        .card-box {
            border-radius: 10px;
            padding: 20px;
            background: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            text-align: center;
        }

        .card-box h2 {
            font-weight: bold;
            color: #273c75;
        }

        footer {
            text-align: center;
            margin-top: 30px;
            color: gray;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4>Central Print</h4>

        <a href="/dashboard">Dashboard</a>
        <a href="/pelanggan">Pelanggan</a>
        <a href="/stok">Stok Barang</a>
        <a href="/pesanan">Pesanan</a>
        <a href="/invoice">Invoice</a>
        <a href="/logout">Logout</a>
    </div>

    <!-- CONTENT -->
    <div class="content">

        <!-- Navbar Atas -->
        <nav class="navbar navbar-light bg-white shadow-sm mb-3">
            <div class="container-fluid">
                <span class="navbar-brand mb-0 h5">Dashboard</span>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <%- body %>

        <!-- FOOTER -->
        <footer>
            <p>© 2026 Central Print Karawang | All rights reserved.</p>
        </footer>

    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>