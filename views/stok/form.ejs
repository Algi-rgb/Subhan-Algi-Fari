<h3><%= stok ? 'Edit Stok Barang' : 'Tambah Stok Barang' %></h3>
<form method="POST" action="<%= stok ? '/stok/edit/' + stok.id : '/stok/tambah' %>">
  <div class="mb-3">
    <label>Nama Barang</label>
    <input type="text" name="nama_barang" class="form-control" value="<%= stok ? stok.nama_barang : '' %>" required>
  </div>
  <div class="mb-3">
    <label>Kategori</label>
    <input type="text" name="kategori" class="form-control" value="<%= stok ? stok.kategori : '' %>">
  </div>
  <div class="mb-3">
    <label>Jumlah</label>
    <input type="number" name="jumlah" class="form-control" value="<%= stok ? stok.jumlah : '' %>">
  </div>
  <div class="mb-3">
    <label>Harga (Rp)</label>
    <input type="number" name="harga" class="form-control" value="<%= stok ? stok.harga : '' %>">
  </div>
  <button type="submit" class="btn btn-success">Simpan</button>
  <a href="/stok" class="btn btn-secondary">Kembali</a>
</form>
