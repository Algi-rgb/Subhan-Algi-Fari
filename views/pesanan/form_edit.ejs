<%- include('../partials/header') %>

<div class="content">
  <h2 class="page-title">Edit Pesanan</h2>

  <form action="/pesanan/edit/<%= pesanan.id %>" method="POST" class="form-box">

    <label>Pelanggan</label>
    <select name="id_pelanggan" required>
      <% pelanggan.forEach(pl => { %>
        <option value="<%= pl.id %>" 
          <%= pl.id === pesanan.id_pelanggan ? "selected" : "" %>>
          <%= pl.nama %>
        </option>
      <% }) %>
    </select>

    <label>Tanggal Pesanan</label>
    <input type="date" name="tanggal_pesanan" value="<%= pesanan.tanggal_pesanan %>" required>

    <label>Total Harga</label>
    <input type="number" name="total_harga" value="<%= pesanan.total_harga %>" required>

    <label>Status Pesanan</label>
    <select name="status_pesanan">
      <option value="proses" <%= pesanan.status_pesanan === 'proses' ? 'selected' : '' %>>Proses</option>
      <option value="selesai" <%= pesanan.status_pesanan === 'selesai' ? 'selected' : '' %>>Selesai</option>
    </select>

    <button type="submit" class="btn-save">Update</button>
    <a href="/pesanan" class="btn-back">Kembali</a>

  </form>
</div>

<%- include('../partials/footer') %>
